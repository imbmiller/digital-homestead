# Copy this to .env and fill in all values before running bootstrap.sh

# ── GitHub ─────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...                        # PAT for homestead-orchestrator GitHub account
                                            # Scopes required: repo, pull_requests, contents
GITHUB_REPO=imbmiller/digital-homestead      # e.g. "acme/digital-homestead"
GITHUB_WEBHOOK_SECRET=                      # Will be generated by bootstrap.sh

# ── Orchestrator auth (generated by bootstrap.sh) ──────────────────────────
ORCHESTRATOR_TOKEN_HASH=                    # SHA-256 of the orchestrator's bearer token

# ── Claude API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...               # Used by the orchestrator container

# ── Gateway config ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:////data/homestead.db
LOG_LEVEL=INFO
SSE_KEEPALIVE_INTERVAL=15
RATE_LIMIT_PER_MINUTE=30

# ── Orchestrator config ─────────────────────────────────────────────────────
GATEWAY_URL=http://gateway:8000
CYCLE_INTERVAL_MINUTES=30
BUDGET_DAILY_LIMIT_USD=5.0
