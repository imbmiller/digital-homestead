# Surfshark WireGuard — get from Surfshark dashboard → Manual Setup → WireGuard → Generate Key
VPN_SERVICE_PROVIDER=surfshark
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=YOUR_WIREGUARD_PRIVATE_KEY_HERE
SERVER_COUNTRIES=Netherlands

# Your user/group IDs — run `id` in terminal to find these
PUID=1000
PGID=1000

# Root path for all media. Must contain: Movies/ TV/ Music/ Books/ Downloads/
MEDIA_ROOT=/mnt/media
