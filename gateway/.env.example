# Anthropic (not used by gateway directly, but orchestrator reads this)
# ANTHROPIC_API_KEY=sk-ant-...

# GitHub integration
GITHUB_TOKEN=ghp_...                        # PAT for homestead-orchestrator account
GITHUB_REPO=imbmiller/digital-homestead      # e.g. "acme/digital-homestead"
GITHUB_WEBHOOK_SECRET=changeme              # 32-byte hex random string

# Security
ORCHESTRATOR_TOKEN_HASH=                    # SHA-256 hex of the orchestrator's bearer token
                                            # Generated by bootstrap.sh

# Database (default works for Docker — override for local dev)
DATABASE_URL=sqlite+aiosqlite:////data/homestead.db

# Server
LOG_LEVEL=INFO
SSE_KEEPALIVE_INTERVAL=15                   # seconds between SSE heartbeats
RATE_LIMIT_PER_MINUTE=30                    # per-agent request cap
